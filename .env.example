# ── Ocean.io ───────────────────────────────
OCEAN_API_KEY=your_ocean_api_token
OCEAN_BASE_URL=https://api.ocean.io
OCEAN_PAGE_SIZE=50

# ── Prospeo ────────────────────────────────
PROSPEO_API_KEY=your_prospeo_api_key
PROSPEO_BASE_URL=https://api.prospeo.io
PROSPEO_SENIORITY_FILTER=C-Suite,Vice President,Founder/Owner

# ── Brevo ──────────────────────────────────
BREVO_API_KEY=your_brevo_api_key
BREVO_BASE_URL=https://api.brevo.com/v3
BREVO_SENDER_NAME=Raj
BREVO_SENDER_EMAIL=contact@rajz.me

# ── Pipeline Limits ────────────────────────
MAX_COMPANIES=10
MAX_CONTACTS_PER_COMPANY=3
DRY_RUN=true
